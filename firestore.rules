rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ATENÇÃO: regras abertas para desenvolvimento/uso familiar sem login.
    // Qualquer pessoa com a config do app pode ler/escrever.
    // Quando adicionar autenticação, troque por:
    //   allow read, write: if request.auth != null;
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
